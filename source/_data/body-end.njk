<script src="/js/subtitle.js"></script>

<script>
  function removeTaskListSpaces() {
      const checkboxes = document.querySelectorAll('.task-list-item-checkbox');
      checkboxes.forEach(function(box) {
          let nextNode = box.nextSibling;
        
          // 如果它确实是一段文本
          if (nextNode && nextNode.nodeType === Node.TEXT_NODE) {
            // 把开头的空白字符（包括空格、换行）强制删掉
            nextNode.textContent = nextNode.textContent.replace(/^\s+/, '');
          }
      });
  }

  // 页面常规加载时执行
  document.addEventListener("DOMContentLoaded", removeTaskListSpaces);
  // 兼容开启 PJAX 的主题（无刷新跳转）
  document.addEventListener("pjax:complete", removeTaskListSpaces);
  document.addEventListener("pjax:success", removeTaskListSpaces);
</script>