/* 让 NexT 主题下的代码块换行 */
.highlight .code pre {
  white-space: pre-wrap !important;   /* 保留缩进同时换行 */
  word-break: break-word !important;  /* 长单词可换行 */
  overflow-wrap: break-word !important;
}

